{
  "name": "clawdgo",
  "version": "1.2.1",
  "description": "ClawdGo 龙虾网安训练营：三层十二维度，W+A-H 训练模式，联网斗虾与可解释战报。v1.2.1 采用 local-first 会话态，不依赖 soul.md。",
  "category": "security-training",
  "license": "MIT-0",
  "author": "ClawdGo Team",
  "files": {
    "skill": "SKILL.md"
  },
  "requires": {
    "env": [],
    "bins": []
  },
  "sideEffects": {
    "fileWrites": [],
    "autonomousModes": [
      {
        "mode": "B self-train",
        "description": "支持手动推进与 cron 定时推送。默认先给命令，duel/cron 子命令在明确指令下可代执行并回传真实结果。"
      },
      {
        "mode": "F arena",
        "description": "5 轮连续红蓝对抗，可由用户发送暂停/退出中断。"
      },
      {
        "mode": "H duel auto",
        "description": "支持 auto start/stop/tick 与 squad start 三龙虾编排。"
      }
    ],
    "cronNote": "B/H 模式包含 cron 示例；执行失败必须返回真实错误，不得伪造成功。"
  },
  "capabilities": [
    "world-mode",
    "guided-training",

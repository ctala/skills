{
  "name": "openclaw-skill-qwen-asr",
  "version": "1.0.0",
  "description": "OpenClaw ASR skill using Qwen3-ASR-0.6B model with dialect support",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "test": "node test.js"
  },
  "keywords": [
    "openclaw",
    "skill",
    "asr",
    "speech-recognition",
    "qwen",
    "dialect"
  ],
  "author": "",
  "license": "Apache-2.0",
  "dependencies": {
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "axios": "^1.6.0",
    "python-shell": "^5.0.0",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  },
  "openclaw": {
    "skillId": "qwen-asr-skill",
    "name": "Qwen ASR Skill",
    "description": "语音转文字服务，支持22种中文方言和多语言识别",
    "version": "1.0.0",
    "author": "OpenClaw Team",
    "icon": "🎤",
    "type": "audio",
    "capabilities": [
      "speech-to-text",
      "dialect-recognition",
      "language-detection"
    ],
    "endpoints": {
      "transcribe": {
        "path": "/transcribe",
        "method": "POST",
        "description": "音频转文字接口",
        "request": {
          "audio": "音频文件路径或base64数据",
          "language": "可选，指定语言/方言（如：Chinese, Cantonese, Sichuan等）",
          "format": "可选，音频格式（默认：wav）"
        },
        "response": {
          "text": "识别结果文本",
          "language": "检测到的语言/方言",
          "confidence": "置信度",
          "duration": "处理时长"
        }
      }
    },
    "dependencies": {
      "python": ">=3.10",
      "qwen-asr": ">=0.1.0",
      "torch": ">=2.0.0"
    }
  }
}